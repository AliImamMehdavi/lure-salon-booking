# Copy to .env.local

# --- Database (required) ---
# Any Postgres connection string. A free Neon project (neon.tech) takes
# about 2 minutes to set up and works great here — see deploy-guide.txt.
DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Session signing (required) ---
# Any long random string. Used to sign admin session cookies — this is
# what actually prevents one salon's session from ever being valid for
# another salon's data. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Booking notification email (optional) ---
NOTIFY_EMAIL=
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- SMS (optional) ---
TEXTBELT_KEY=textbelt

# --- Reminder endpoint protection (optional) ---
CRON_SECRET=
